  "version": "0.2.0",
  "configurations": [
    {
      "name": "app",
      "type": "debugpy",
      "request": "launch",
      "module": "app",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": { "PYTHONPATH": "${workspaceFolder}/app/src" }
    },
    {
      "name": "console",
      "type": "debugpy",
      "request": "launch",
      "module": "console",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": { "PYTHONPATH": "${workspaceFolder}/console/src" }
    }
  ]
}
